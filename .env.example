# Database
DATABASE_URL="postgresql://username:password@localhost:5432/cloud_manager?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
NEXTAUTH_SECRET="your-nextauth-secret-change-this-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Cloud Provider API Keys (Mock/Development)
AWS_ACCESS_KEY_ID="mock-aws-access-key"
AWS_SECRET_ACCESS_KEY="mock-aws-secret-key"
AWS_REGION="us-east-1"

AZURE_CLIENT_ID="mock-azure-client-id"
AZURE_CLIENT_SECRET="mock-azure-client-secret"
AZURE_TENANT_ID="mock-azure-tenant-id"
AZURE_SUBSCRIPTION_ID="mock-azure-subscription-id"

GCP_PROJECT_ID="mock-gcp-project-id"
GCP_PRIVATE_KEY="mock-gcp-private-key"
GCP_CLIENT_EMAIL="mock-gcp-client-email"

# Stripe (Payments)
STRIPE_PUBLIC_KEY="pk_test_your_stripe_public_key"
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"

# App Settings
APP_NAME="Cloud Infrastructure Manager"
APP_URL="http://localhost:3000"
NODE_ENV="development"

# Email (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"

# Monitoring
SENTRY_DSN=""
LOG_LEVEL="debug"

# Feature Flags
ENABLE_BILLING="true"
ENABLE_ADVANCED_MONITORING="true"
ENABLE_AI_RECOMMENDATIONS="true"
